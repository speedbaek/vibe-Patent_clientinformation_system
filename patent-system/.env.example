# MongoDB
MONGODB_URI=mongodb://localhost:27017/patent-system

# Server
PORT=4000
NODE_ENV=development

# Encryption (AES-256)
AES_ENCRYPTION_KEY=your-32-byte-hex-key-here-change-in-production
AES_IV_LENGTH=16

# JWT (Phase 2 - Admin)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=8h

# Token
TOKEN_EXPIRY_DAYS=7

# File Upload
MAX_FILE_SIZE=10485760
MAX_TOTAL_SIZE=52428800
UPLOAD_DIR=./uploads

# CORS
FRONTEND_URL=http://localhost:5173
