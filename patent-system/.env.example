# Server
PORT=4000
NODE_ENV=development

# SQLite (자동 생성됨)
DB_PATH=./data/patent.db

# Encryption (AES-256) - 프로덕션에서 반드시 변경
AES_ENCRYPTION_KEY=your-32-byte-hex-key-here-change-in-production
AES_IV_LENGTH=16

# File Upload
MAX_FILE_SIZE=10485760
MAX_TOTAL_SIZE=52428800
UPLOAD_DIR=./uploads

# CORS
FRONTEND_URL=http://localhost:5173

# Admin Password
ADMIN_PASSWORD=admin1234

# SMTP Email (선택 - 미설정 시 콘솔 출력만)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
