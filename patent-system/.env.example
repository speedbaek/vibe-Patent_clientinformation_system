# Server
PORT=4000
NODE_ENV=development

# SQLite (자동 생성됨)
# Railway 배포 시: /data/patent.db (볼륨 마운트 경로)
DB_PATH=./data/patent.db

# Encryption (AES-256)
# 프로덕션: 반드시 64자 hex 키 설정 필요 (미설정 시 서버 시작 불가)
# 키 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 개발: 미설정 시 자동 dev 키 사용 (경고 출력)
AES_ENCRYPTION_KEY=

AES_IV_LENGTH=16

# File Upload
MAX_FILE_SIZE=10485760
MAX_TOTAL_SIZE=52428800
# Railway 배포 시: /data/uploads (볼륨 마운트 경로)
UPLOAD_DIR=./uploads

# CORS
# 프로덕션에서 프론트엔드와 같은 서버면 설정 불필요
# 개발: 미설정 시 http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Admin Password
# 프로덕션: 반드시 강력한 비밀번호 설정 필요 (미설정 시 서버 시작 불가)
# 개발: 미설정 시 기본값 'admin1234' 사용
ADMIN_PASSWORD=

# SMTP Email (선택 - 미설정 시 콘솔 출력만)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
